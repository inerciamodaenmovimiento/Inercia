/* Importar fuentes de lujo */
@import url('https://googleapis.com');

body {
    background-color: #fff;
    color: #000;
    margin: 0;
    padding: 0;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
}

/* Contenedor principal con márgenes de revista */
.editorial-grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
    display: grid;
    grid-template-columns: repeat(12, 1fr); /* Sistema de 12 columnas */
    gap: 20px;
}

/* Encabezado */
.main-header {
    grid-column: 1 / 13;
    text-align: center;
    margin-bottom: 80px;
}

.logo {
    font-family: 'Bodoni Moda', serif;
    font-size: 8rem;
    font-weight: 900;
    margin: 0;
    letter-spacing: -5px;
    text-transform: uppercase;
}

nav {
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
    padding: 10px 0;
    word-spacing: 30px;
    font-size: 0.8rem;
    letter-spacing: 3px;
}

/* Sección Hero con solapamiento */
.hero-section {
    grid-column: 1 / 9; /* Ocupa la parte izquierda */
    position: relative;
    background: #f0f0f0; /* Fondo gris temporal por si no carga la imagen */
    min-height: 500px;
}

.hero-text {
    grid-column: 7 / 13; /* Empieza antes de que termine la imagen */
    grid-row: 1;
    z-index: 10;
    padding-top: 100px;
}

.title-overlap {
    font-family: 'Bodoni Moda', serif;
    font-size: 5rem;
    line-height: 0.8;
    background: white; /* Esto crea el efecto de recorte */
    padding: 20px;
}

/* El manifiesto lateral */
.manifesto {
    grid-column: 2 / 6;
    margin-top: 50px;
    border-left: 1px solid #000;
    padding-left: 20px;
}

.story-title {
    font-family: 'Bodoni Moda', serif;
    font-size: 3rem;
    font-style: italic;
}
